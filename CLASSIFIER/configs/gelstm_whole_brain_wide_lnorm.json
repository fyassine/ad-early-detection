{
    "rnn_type": "lstm",
    "lstm_hidden": 64,
    "lstm_layers": 1,
    "lstm_dropout": 0.15,
    "classifier_hidden": 64,
    "classifier_norm": "layernorm",
    "use_time_delta": true,
    "graph_pool": "mean",
    "freeze_encoder": true,
    "standardize_features": true,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "epochs": 50,
    "early_stopping_patience": 15,
    "batch_size": 16,
    "use_class_cost_weights": true,
    "grad_clip": 1.0,
    "n_folds": 5
}
